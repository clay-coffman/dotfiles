# -----------------------------------------------------------------------------
# Theme: follows system color scheme via theme-sync daemon
# -----------------------------------------------------------------------------
# `current.conf` is a symlink managed by ~/.local/bin/theme-sync pointing at
# github-dark-default.conf or github-light-default.conf. -q so a fresh tmux
# server before the daemon has run the first time doesn't error out.

{{ if has (output "hostname" "-s" | trim) .remoteHosts -}}
source-file ~/.config/tmux/themes/github-dark-default.conf
{{- else if eq .chezmoi.os "darwin" -}}
if-shell 'defaults read -g AppleInterfaceStyle 2>/dev/null | grep -q Dark' \
    'source-file ~/.config/tmux/themes/github-dark-default.conf' \
    'source-file ~/.config/tmux/themes/github-light-default.conf'
{{- else -}}
source-file -q ~/.config/tmux/themes/current.conf
{{- end }}

set -g message-style          "bg=#{@thm_surface_0},fg=#{@thm_overlay_2}"
set -g message-command-style  "bg=#{@thm_surface_0},fg=#{@thm_blue}"
set -g mode-style             "bg=#{@thm_surface_0},fg=#{@thm_blue}"

# -----------------------------------------------------------------------------
# General Settings
# -----------------------------------------------------------------------------

# set tmux plugin install path
set-environment -g TMUX_PLUGIN_MANAGER_PATH '{{ .chezmoi.homeDir }}/.config/tmux/plugins/'

# Set prefix key to Ctrl-a
set-option -g prefix C-a

# set scrollback history limit (default 2000)
set -g history-limit 10000

# Set escape time to 0 or 10ms for faster key response (default 500ms)
# Use 'set -sg' for server-global setting
set -sg escape-time 10

# Start window numbering at 1 (default is 0)
set -g base-index 1
setw -g pane-base-index 1

# Renumber windows automatically when a window is closed
set -g renumber-windows on

# enable mouse support
set -g mouse on

# -----------------------------------------------------------------------------
# Terminal and Display Settings
# -----------------------------------------------------------------------------

# set default term and enable true color support
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*256color*:Tc"
# cursor shape sequences (lets zsh-vi-mode switch cursor inside tmux)
set -ga terminal-overrides ',*:Ss=\E[%p1%d q:Se=\E[2 q'

# enable focus events
set -g focus-events on

# allow passthrough for image protocols (image.nvim) and Claude Code desktop
# notifications. `all` (not `on`) so passthrough still reaches Ghostty when the
# CC pane is in a background window — i.e. exactly when you want the alert.
set -gq allow-passthrough all

# extended keys: let Claude Code (and other TUIs) see Shift+Enter inside tmux
set -s extended-keys on
set -as terminal-features 'xterm*:extkeys'
set -g update-environment "DISPLAY KRB5CCNAME SSH_ASKPASS SSH_AUTH_SOCK SSH_AGENT_PID SSH_CONNECTION WINDOWID XAUTHORITY TERM TERM_PROGRAM WAYLAND_DISPLAY XDG_RUNTIME_DIR XDG_SESSION_TYPE XDG_CURRENT_DESKTOP DBUS_SESSION_BUS_ADDRESS"
set -g visual-activity off

# -----------------------------------------------------------------------------
# Splits, Resizing, Copy Mode
# -----------------------------------------------------------------------------

# Split panes using v and s (same as vim)
bind v split-window -h -c "#{pane_current_path}"
bind s split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# Grab a window via interactive chooser and join it here as a pane
bind g choose-window "join-pane -v -s '%%'"

# Make pane resizing repeatable by holding down the key
bind -r H resize-pane -L 10
bind -r J resize-pane -D 10
bind -r K resize-pane -U 10
bind -r L resize-pane -R 10

# enable vi mode in copy
setw -g mode-keys vi

# reload tmux.conf
bind r source-file ~/.tmux.conf \; display-message "Config reloaded"

# -----------------------------------------------------------------------------
# Status Bar and Theme
# -----------------------------------------------------------------------------

# Status line position and style
set -g status-position top
set -g status-style "bg=#{@thm_bg},fg=#{@thm_overlay_2}"
set -g status-justify "left"

# Second status row: a thin full-width rule separating the bar from the panes.
# tmux has no repeat-char format, so this is a literal 600-column run that gets
# truncated to the terminal width (600 covers any realistic display).
set -g status 2
set -g status-format[1] "#[fg=#{@thm_surface_1},bg=#{@thm_bg},none]────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────"

# Left side of status line: session only — the window list follows immediately
# (status-justify left). The current window's pane list is centred in the bar;
# the zoom flag lives in the current window's tab.
set -g status-left-length 100
set -g status-left ""
set -ga status-left "#{?client_prefix,#{#[bg=#{@thm_red},fg=#{@thm_bg},bold]  #S },#{#[bg=#{@thm_bg},fg=#{@thm_green}]  #S }}"
set -ga status-left "#[bg=#{@thm_bg},fg=#{@thm_overlay_0},none]│"
{{- if has (output "hostname" "-s" | trim) .remoteHosts }}
set -ga status-left "#[bg=red,fg=white,bold] REMOTE #[default]"
{{- end }}

# Right side of status line
set -g status-right-length 100
set -g status-right ""
set -ga status-right "#{?#{e│<=:10,#{battery_percentage}},#{#[bg=#{@thm_red},fg=#{@thm_bg}]},#{#[bg=#{@thm_bg},fg=#{@thm_pink}]}} #{battery_icon} #{battery_percentage} "
set -ga status-right "#[bg=#{@thm_bg},fg=#{@thm_overlay_0}, none]│"
set -ga status-right "#[bg=#{@thm_bg}]#{?#{==:#{online_status},ok},#[fg=#{@thm_mauve}] 󰖩 on ,#[fg=#{@thm_red},bold]#[reverse] 󰖪 off }"
set -ga status-right "#[bg=#{@thm_bg},fg=#{@thm_overlay_0}, none]│"
set -ga status-right "#[bg=#{@thm_bg},fg=#{@thm_blue}] 󰭦 %Y-%m-%d 󰅐 %H:%M "

# Centre of status line: all panes in the current window, active pane
# highlighted (peach chip, like the current window tab). #{P:a,b} loops over
# the window's panes, using format b for the active pane.
#
# status-format[0] must be set to the FULL default plus the centre section:
# appending to an unset array element does NOT inherit the default (unlike
# scalar options such as terminal-overrides), so `-u` + `-a` blanks the bar.
# The first line is the verbatim tmux 3.6 default — after a tmux upgrade,
# re-check it with: tmux -f /dev/null -L x start \; show -gv 'status-format[0]'
set -g status-format[0] "#[align=left range=left #{E:status-left-style}]#[push-default]#{T;=/#{status-left-length}:status-left}#[pop-default]#[norange default]#[list=on align=#{status-justify}]#[list=left-marker]<#[list=right-marker]>#[list=on]#{W:#[range=window|#{window_index} #{E:window-status-style}#{?#{&&:#{window_last_flag},#{!=:#{E:window-status-last-style},default}}, #{E:window-status-last-style},}#{?#{&&:#{window_bell_flag},#{!=:#{E:window-status-bell-style},default}}, #{E:window-status-bell-style},#{?#{&&:#{||:#{window_activity_flag},#{window_silence_flag}},#{!=:#{E:window-status-activity-style},default}}, #{E:window-status-activity-style},}}]#[push-default]#{T:window-status-format}#[pop-default]#[norange default]#{?loop_last_flag,,#{window-status-separator}},#[range=window|#{window_index} list=focus #{?#{!=:#{E:window-status-current-style},default},#{E:window-status-current-style},#{E:window-status-style}}#{?#{&&:#{window_last_flag},#{!=:#{E:window-status-last-style},default}}, #{E:window-status-last-style},}#{?#{&&:#{window_bell_flag},#{!=:#{E:window-status-bell-style},default}}, #{E:window-status-bell-style},#{?#{&&:#{||:#{window_activity_flag},#{window_silence_flag}},#{!=:#{E:window-status-activity-style},default}}, #{E:window-status-activity-style},}}]#[push-default]#{T:window-status-current-format}#[pop-default]#[norange list=on default]#{?loop_last_flag,,#{window-status-separator}}}#[nolist align=right range=right #{E:status-right-style}]#[push-default]#{T;=/#{status-right-length}:status-right}#[pop-default]#[norange default]"
set -ga status-format[0] "#[nolist align=absolute-centre]"
set -ga status-format[0] "#{P:#{?#{==:#{pane_index},1},,#{#[bg=#{@thm_bg},fg=#{@thm_overlay_0},none]│}}#{#[bg=#{@thm_bg},fg=#{@thm_overlay_1}] #{pane_index} #{s|^[0-9]+[.][0-9]+[.][0-9]+$|claude|:pane_current_command} },#{?#{==:#{pane_index},1},,#{#[bg=#{@thm_bg},fg=#{@thm_overlay_0},none]│}}#{#[bg=#{@thm_peach},fg=#{@thm_bg},bold] #{pane_index} #{s|^[0-9]+[.][0-9]+[.][0-9]+$|claude|:pane_current_command} }}"

# -----------------------------------------------------------------------------
# Window and Border Settings
# -----------------------------------------------------------------------------

# pane border look and feel: heavy peach border marks the active pane; the
# pane list centred in the status bar is the primary indicator (no badge row)
setw -g pane-border-status off
setw -g pane-active-border-style "fg=#{@thm_peach},bold"
setw -g pane-border-style "fg=#{@thm_surface_1}"
setw -g pane-border-lines heavy

# dim inactive panes to make active pane stand out
set -g window-style "bg=#{@thm_bg_dim},fg=#{@thm_text}"
set -g window-active-style "bg=#{@thm_bg},fg=#{@thm_text}"

# window look and feel
set -wg automatic-rename on
# #W passes through two fixes: Claude Code's binary is named for its version
# (shows as e.g. "2.1.217" -> rewrite to "claude"), and the nerd-font window
# name plugin prefixes unknown commands with a "? " fallback icon (strip it)
set -g window-status-format " #I #{s|^[?] ||:#{s|[0-9]+[.][0-9]+[.][0-9]+|claude|:window_name}} "
set -g window-status-style "bg=#{@thm_bg},fg=#{@thm_rosewater}"
set -g window-status-last-style "bg=#{@thm_bg},fg=#{@thm_peach}"
set -g window-status-activity-style "bg=#{@thm_red},fg=#{@thm_bg}"
set -g window-status-bell-style "bg=#{@thm_red},fg=#{@thm_bg},bold"
set -gF window-status-separator "#[bg=#{@thm_bg},fg=#{@thm_overlay_0}]│"

set -g window-status-current-format " #I #{s|^[?] ||:#{s|[0-9]+[.][0-9]+[.][0-9]+|claude|:window_name}}#{?window_zoomed_flag,  ,} "
set -g window-status-current-style "bg=#{@thm_peach},fg=#{@thm_bg},bold"

# -----------------------------------------------------------------------------
# Plugins and Options
# -----------------------------------------------------------------------------

# List of plugins (removed dark-notify)
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'schasse/tmux-jump'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-yank'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'tmux-plugins/tmux-online-status'
set -g @plugin 'tmux-plugins/tmux-battery'
set -g @plugin 'laktak/extrakto'
set -g @plugin 'jaclu/tmux-menus'
set -g @plugin 'joshmedeski/tmux-nerd-font-window-name'
set -g @plugin 'b0o/tmux-autoreload'
set -g @plugin 'omerxx/tmux-sessionx'

# -- Plugin Options

# tmux-resurrect options
set -g @resurrect-strategy-nvim 'session'

# tmux-continuum options
set -g @continuum-restore 'on'
# set -g @continuum-boot-options 'kitty'

# tmux-online-status
set -g @online_icon "ok"
set -g @offline_icon "nok"

# tmux-sessionx
set -g @sessionx-bind 'o'
set -g @sessionx-zoxide-mode 'on'

# -----------------------------------------------------------------------------
# Initialize TPM
# -----------------------------------------------------------------------------

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run '{{ .chezmoi.homeDir }}/.config/tmux/plugins/tpm/tpm'
