[
    {
        "defaults": {
            "link": {
                "relink": true
            }
        }
    },
    {
        "clean": ["~"]
    },
    {
        "link": {
            "~/.tmux.conf": "tmux.conf",
            "~/.oh-my-zsh/custom/custom_alias.zsh": {
                "path": "custom_alias.zsh",
                "create": true,
                "force": true
            },
            "~/.config/nvim/coc-settings.json": {
                "path": "coc-settings.json",
                "create": true,
                "force": true
            },
            "~/.config/nvim/init.vim": {
                "path": "init.vim",
                "create": true,
                "force": true
            },
            "~/.config/nvim/basic.vim": {
                "path": "basic.vim",
                "create": true,
                "force": true
            },
            "~/.config/nvim/extended.vim": {
                "path": "extended.vim",
                "create": true,
                "force": true
            },
            "~/.config/nvim/filetypes.vim": {
                "path": "filetypes.vim",
                "create": true,
                "force": true
            },
            "~/.config/nvim/plugin_list.vim": {
                "path": "plugin_list.vim",
                "create": true,
                "force": true
            },
            "~/.config/nvim/plugins_config.vim": {
                "path": "plugins_config.vim",
                "create": true,
                "force": true
            },
            "~/.clay_mbp_2019.json": "clay_mbp_2019.json",
            "~/.zshrc": "zshrc",
            "~/.bash_profile": "bash_profile",
            "~/.bashrc": "bashrc"
        }
    },
    {
        "shell": [
            ["git submodule update --init --recursive", "Installing submodules"]
        ]
    }
]
