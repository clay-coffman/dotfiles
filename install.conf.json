[
    {
        "defaults": {
            "link": {
                "relink": true,
                "create": true
            }
        }
    },
    {
        "clean": ["~"]
    },
    {
        "link": {
            "~/.dotfiles": "",
            "~/.tmux.conf": "tmux.conf",
            "~/.vimrc": "vimrc",
            "~/.zshrc": "zshrc",
            "~/.bash_profile": "bash_profile",
            "~/.bashrc": "bashrc"
        }
    },
    {
        "shell": [
            ["git submodule update --init --recursive", "Installing submodules"]
        ]
    }
]
