[
    {
        "defaults": {
            "link": {
                "relink": true
            }
        }
    },
    {
        "clean": ["~"]
    },
    {
        "link": {
            "~/.tidyrc": "tidyrc",
            "~/.tmux.conf": "tmux.conf",
            "~/.oh-my-zsh/custom/custom_alias.zsh": {
                "path": "custom_alias.zsh",
                "create": true,
                "force": true
            },
            "~/.config/": {
		    "glob": true,
                "path": "config/*",
		"create": true,
		"force": true
            },
            "~/.clay_mbp_2019.json": "clay_mbp_2019.json",
            "~/.zshrc": "zshrc",
            "~/.bash_profile": "bash_profile",
            "~/.bashrc": "bashrc"
        }
    },
    {
        "shell": [
            ["git submodule update --init --recursive", "Installing submodules"]
        ]
    }
]
