[
    {
        "defaults": {
            "link": {
                "relink": true
            }
        }
    },
    {
        "clean": [
            "~"
        ]
    },
    {
        "link": {
            "~/.tidyrc": "tidyrc",
            "~/.tmux.conf": "tmux.conf",
            "~/.oh-my-zsh/custom/custom_alias.zsh": {
                "path": "custom_alias.zsh",
                "create": true,
                "force": true
            },
            "~/.config/": {
                "glob": true,
                "path": "config/*",
                "create": true,
                "force": true
            },
            "~/.terminfo/": {
                "glob": true,
                "path": "terminfo/*",
                "create": true,
                "force": true
            },
            "~/.zshrc": "zshrc",
            "~/.bash_profile": "bash_profile",
            "~/.bashrc": "bashrc",
            "~/.p10k.zsh": "p10k.zsh"
        }
    },
    {
        "shell": [
            [
                "git submodule update --init --recursive",
                "Installing submodules"
            ]
        ]
    }
]
