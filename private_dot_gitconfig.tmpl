# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
	name = Clay Coffman
	email = {{ .email }}
{{ if not (has (output "hostname" "-s" | trim) .remoteHosts) -}}
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKBsebZK7f4baWHe5lGYfskQB66+NrW4hyhVP2P7oRL5
{{- end }}
[init]
	defaultBranch = main
{{ if not (has (output "hostname" "-s" | trim) .remoteHosts) -}}
[gpg]
	format = ssh
[gpg "ssh"]
	program = {{ if eq .chezmoi.os "darwin" }}/Applications/1Password.app/Contents/MacOS/op-ssh-sign{{ else }}/opt/1Password/op-ssh-sign{{ end }}
[commit]
	gpgsign = true
{{ end -}}
[diff]
	tool = nvimdiff
[difftool]
	prompt = false
