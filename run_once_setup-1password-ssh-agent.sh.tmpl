{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# Link the macOS 1Password agent socket to ~/.1password/agent.sock so that
# ~/.ssh/config's `IdentityAgent ~/.1password/agent.sock` resolves on macOS.
# Requires 1Password → Settings → Developer → "Use the SSH Agent" to be enabled
# first; if the source socket doesn't exist yet, we skip and the user can re-run
# `chezmoi apply` after enabling.
set -euo pipefail

SRC="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
DST="$HOME/.1password/agent.sock"

if [ ! -S "$SRC" ]; then
  echo "1Password SSH agent socket not found at $SRC — enable it in 1Password → Settings → Developer, then re-run chezmoi apply." >&2
  exit 0
fi

mkdir -p "$(dirname "$DST")"
if [ -L "$DST" ] && [ "$(readlink "$DST")" = "$SRC" ]; then
  exit 0
fi
ln -sfn "$SRC" "$DST"
echo "Linked 1Password SSH agent socket → $DST"
{{- end }}
