#!/usr/bin/env bash
# Re-runs whenever ~/.tool-versions changes (hash below).
# tool-versions-hash: {{ include "dot_tool-versions" | sha256sum }}
set -euo pipefail

if ! command -v asdf >/dev/null 2>&1; then
	echo "asdf not installed — skipping node bootstrap." >&2
	exit 0
fi

# Install any versions pinned in ~/.tool-versions that aren't already present.
asdf install

# Enable corepack (bundled with node) so pnpm/yarn are available. On a fresh
# bootstrap corepack isn't on PATH yet (shims not generated), so resolve it
# from the active nodejs install directory.
node_dir="$(asdf where nodejs 2>/dev/null || true)"
if [ -n "$node_dir" ] && [ -x "$node_dir/bin/corepack" ]; then
	"$node_dir/bin/corepack" enable --install-directory "$node_dir/bin"
elif command -v corepack >/dev/null 2>&1; then
	corepack enable
else
	echo "corepack not found — skipping pnpm/yarn shims." >&2
fi

# Surface the new shims (pnpm, yarn, corepack) through asdf.
asdf reshim nodejs
